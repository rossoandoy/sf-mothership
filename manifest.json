{
  "manifest_version": 3,
  "name": "SF Mothership",
  "version": "0.1.0",
  "description": "Salesforce導入支援Chrome拡張母艦 — 現場の面倒をすぐ小ツール化",
  "permissions": [
    "cookies",
    "activeTab",
    "sidePanel",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "*://*.salesforce.com/*",
    "*://*.force.com/*",
    "*://*.lightning.force.com/*",
    "*://*.my.salesforce.com/*",
    "*://*.salesforce-setup.com/*"
  ],
  "background": {
    "service_worker": "src/background/serviceWorker.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.salesforce.com/*",
        "*://*.force.com/*",
        "*://*.lightning.force.com/*",
        "*://*.my.salesforce.com/*"
      ],
      "js": ["src/content/contentScript.ts"],
      "run_at": "document_idle"
    }
  ],
  "side_panel": {
    "default_path": "src/sidepanel/sidepanel.html"
  },
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "SF Mothership"
  },
  "options_page": "src/options/options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
